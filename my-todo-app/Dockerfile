# 1. ベースとなるOS（イメージ）を決定する
FROM node:20-alpine
# 解説: Node.jsのバージョン20が入った、軽量なLinux(Alpine)を土台として使います。

# 2. コンテナ内の作業ディレクトリ（部屋）を決める
WORKDIR /app
# 解説: これ以降の命令を実行する場所を、コンテナ内の「/app」フォルダに固定します。

# 3. パッケージのリスト（設計図のリスト）をコピーする
COPY package*.json ./
# 解説: ライブラリのリストが書かれたファイルを、先にコンテナの中にコピーします。

# 4. ライブラリをインストールする
RUN npm install
# 解説: コピーしたリストを元に、Reactに必要な部品をすべてダウンロードします。

# 5. 全てのプログラムコードをコピーする
COPY . .
# 解説: あなたが書いたプログラム本体を、コンテナの中に全て流し込みます。

# 6. 3000番ポートを開放する
EXPOSE 3000
# 解説: ブラウザからアクセスできるように、3000番という窓口を開けておきます。

# 7. アプリを起動する
CMD ["npm", "start"]
# 解説: コンテナが立ち上がった瞬間に、Reactを起動させる。
